# AniList OAuth — Desktop
ANILIST_DESKTOP_CLIENT_ID=your_desktop_client_id
ANILIST_DESKTOP_CLIENT_SECRET=your_desktop_client_secret
ANILIST_DESKTOP_REDIRECT_URI=https://shiori.local/auth

# AniList OAuth — Android
ANILIST_ANDROID_CLIENT_ID=your_android_client_id
ANILIST_ANDROID_CLIENT_SECRET=your_android_client_secret
ANILIST_ANDROID_REDIRECT_URI=shiori://auth

# Vite-exposed (VITE_ prefix required for frontend access)
VITE_ANILIST_DESKTOP_CLIENT_ID=your_desktop_client_id
VITE_ANILIST_ANDROID_CLIENT_ID=your_android_client_id
