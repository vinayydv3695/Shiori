# Maintainer: Vinay Kumar <vinayydv343@gmail.com>
pkgname=shiori-rin-bin
pkgver=0.1.9
pkgrel=1
pkgdesc="Modern offline-first eBook library manager built with Tauri, React, and Rust (binary)"
arch=('x86_64')
url="https://github.com/vinayydv3695/Shiori"
license=('MIT')
depends=(
    'webkit2gtk-4.1'
    'gtk3'
    'libayatana-appindicator'
    'librsvg'
    'sqlite'
)
provides=('shiori-rin')
conflicts=(
    'shiori-rin'
    'shiori-ebook'
    'shiori-ebook-bin'
)
source=("Shiori_${pkgver}_linux_amd64.tar.gz::${url}/releases/download/v${pkgver}/Shiori_${pkgver}_linux_amd64.tar.gz")
sha256sums=('SKIP')

package() {
    # Extract release tarball directly into package directory
    bsdtar -xf "Shiori_${pkgver}_linux_amd64.tar.gz" -C "${pkgdir}"

    # Fix permissions
    chmod -R u+rwX,go+rX,go-w "${pkgdir}"
}
