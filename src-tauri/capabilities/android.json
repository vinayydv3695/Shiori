{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "android-capability",
  "description": "Capabilities for Android-only plugins (SAF and OAuth auth)",
  "platforms": [
    "android"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "android-saf:default",
    "android-auth:default",
    "android-package-install:default",
    "android-package-install:allow-check-permissions",
    "android-package-install:allow-request-permissions",
    "android-package-install:allow-install",
    "shell:allow-open",
    "android-auth:allow-start-oauth-login",
    "android-auth:allow-get-pending-oauth-data",
    "android-auth:allow-set-secure-token",
    "android-auth:allow-get-secure-token",
    "android-auth:allow-clear-secure-token",
    "android-auth:allow-ping",
    "android-saf:allow-select-folder",
    "android-saf:allow-select-files",
    "android-saf:allow-enumerate-tree",
    "android-saf:allow-copy-document",
    "android-saf:allow-create-document",
    "android-saf:allow-write-document",
    "android-saf:allow-check-storage-permission",
    "android-saf:allow-request-storage-permission",
    "android-saf:allow-open-app-settings",
    "android-saf:allow-solve-cloudflare",
    "android-saf:allow-ping"
  ]
}
