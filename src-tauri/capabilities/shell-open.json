{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "shell-open-urls",
  "windows": [
    "main"
  ],
  "permissions": [
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "url": "https://**"
        },
        {
          "url": "http://**"
        },
        {
          "url": "mailto:*"
        }
      ]
    }
  ]
}
