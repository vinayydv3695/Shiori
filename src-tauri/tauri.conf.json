{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shiori",
  "version": "1.54.0",
  "identifier": "com.tauri.shiori",
  "build": {
    "beforeDevCommand": "vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "tsc -b && vite build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "2026 Shiori Contributors",
    "targets": [
      "deb",
      "rpm",
      "appimage",
      "nsis",
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": ""
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "librsvg2-common"
        ],
        "section": "utils"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "libayatana-appindicator-gtk3",
          "librsvg2"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https: blob: data: shiori-proxy: http://shiori-proxy.localhost; font-src 'self' asset: http://asset.localhost data:; connect-src 'self' ipc: http://ipc.localhost https://openlibrary.org https://covers.openlibrary.org https://graphql.anilist.co https://api.mangadex.org https://gutendex.com https://freeonlinek.top https://weebrook.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/**",
          "$APPDATA/**",
          "$HOME/**"
        ]
      },
      "capabilities": [
        "default"
      ]
    },
    "windows": []
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/vinayydv3695/Shiori/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0NTY5ODY4ODAwMjg3M0MKUldROGh3S0FhSmhXSk5NNmp2dUJueGtTVi8rZjZvTHhGb0d3QlJLRDZ2LzdFUFFYeWd6cDRTYzMK"
    }
  }
}
