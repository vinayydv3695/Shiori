{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shiori",
  "version": "0.1.0",
  "identifier": "com.tauri.shiori",
  "build": {
    "beforeDevCommand": "vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "tsc -b && vite build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "2026 Shiori Contributors",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": ""
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "librsvg2-common"
        ],
        "section": "utils"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "libayatana-appindicator-gtk3",
          "librsvg2"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: blob: data:; font-src 'self' asset: data:; connect-src 'self' ipc: http://ipc.localhost https://openlibrary.org https://covers.openlibrary.org https://graphql.anilist.co",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/**",
          "$APPDATA/**",
          "$HOME/**"
        ]
      },
      "capabilities": ["default"]
    },
    "windows": [
      {
        "title": "Shiori",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
